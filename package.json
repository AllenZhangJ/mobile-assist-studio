{
  "name": "ios-assist-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local iOS assist automation studio powered by Appium and WebDriverAgent.",
  "scripts": {
    "appium": "appium --address 127.0.0.1 --port 4723",
    "check": "fvm dart run tool/v4_boundary_check.dart",
    "verify:all": "fvm dart run tool/v4_verify.dart",
    "v2:boundary": "fvm dart run tool/v2_boundary_check.dart",
    "v2:macos-build": "fvm dart run tool/macos_build_smoke.dart",
    "v2:verify": "fvm dart run tool/v2_verify.dart",
    "v4:boundary": "fvm dart run tool/v4_boundary_check.dart",
    "v4:verify": "fvm dart run tool/v4_verify.dart",
    "v4:ios-smoke": "cd packages/studio_runtime && fvm dart run tool/v4_ios_smoke.dart --out-dir ../../recordings/v4-smoke/ios",
    "v4:android-smoke": "cd packages/studio_runtime && fvm dart run tool/v4_android_smoke.dart --out-dir ../../recordings/v4-smoke/android",
    "v4:smoke-readiness": "fvm dart run tool/v4_smoke_readiness.dart",
    "smoke:v2-boundary": "fvm dart run tool/v2_boundary_check.dart",
    "smoke:v4-boundary": "fvm dart run tool/v4_boundary_check.dart",
    "smoke:macos-build": "fvm dart run tool/macos_build_smoke.dart",
    "legacy:init:connected": "node legacy/node/src/ios-coordinate-init.mjs --config config/connected-device.sequence.json",
    "legacy:console:connected": "node legacy/node/src/ios-assist-console.mjs --config config/connected-device.sequence.json",
    "legacy:click:connected": "node legacy/node/src/ios-coordinate-click.mjs --config config/connected-device.sequence.json --start-appium",
    "legacy:record:connected": "node legacy/node/src/ios-coordinate-record-server.mjs --config config/connected-device.sequence.json --start-appium",
    "legacy:record:html:connected": "node legacy/node/src/ios-coordinate-record.mjs --config config/connected-device.sequence.json --start-appium",
    "legacy:pick-d:connected": "node legacy/node/src/ios-coordinate-pick-point.mjs --config config/connected-device.sequence.json --label D --start-appium",
    "legacy:dry-run:connected": "node legacy/node/src/ios-coordinate-click.mjs --config config/connected-device.sequence.json --dry-run --loops 1",
    "legacy:start:connected": "node legacy/node/src/ios-coordinate-click.mjs --config config/connected-device.sequence.json",
    "legacy:dry-run": "node legacy/node/src/ios-coordinate-click.mjs --config config/example.sequence.json --dry-run",
    "legacy:start": "node legacy/node/src/ios-coordinate-click.mjs --config config/example.sequence.json",
    "legacy:validate:connected": "node legacy/node/src/ios-assist-validate.mjs --config config/connected-device.sequence.json",
    "legacy:validate": "node legacy/node/src/ios-assist-validate.mjs --config config/example.sequence.json",
    "legacy:smoke:acceptance": "node legacy/node/src/ios-assist-acceptance-smoke.mjs",
    "legacy:smoke:click": "node legacy/node/src/ios-coordinate-click-smoke.mjs",
    "legacy:smoke:console": "node legacy/node/src/ios-assist-console-smoke.mjs",
    "legacy:smoke:console-guards": "node legacy/node/src/ios-assist-console-guards-smoke.mjs",
    "legacy:smoke:device-discovery": "node legacy/node/src/ios-assist-device-discovery-smoke.mjs",
    "legacy:smoke:evidence": "node legacy/node/src/ios-assist-evidence-smoke.mjs",
    "legacy:smoke:legacy-tools": "node legacy/node/src/ios-assist-legacy-tools-smoke.mjs",
    "legacy:smoke:public-payload": "node legacy/node/src/ios-assist-public-payload-smoke.mjs",
    "legacy:smoke:public-text": "node legacy/node/src/ios-assist-public-text-smoke.mjs",
    "legacy:smoke:runner": "node legacy/node/src/ios-assist-runner-smoke.mjs",
    "legacy:smoke:session": "node legacy/node/src/ios-assist-session-smoke.mjs",
    "legacy:smoke:validate": "node legacy/node/src/ios-assist-validate-smoke.mjs",
    "legacy:smoke:visual": "node legacy/node/src/ios-assist-visual-smoke.mjs",
    "legacy:smoke:workflow": "node legacy/node/src/ios-assist-workflow-smoke.mjs",
    "legacy:check": "node legacy/node/src/ios-assist-legacy-check.mjs",
    "legacy:verify": "npm run legacy:validate && npm run legacy:validate:connected && npm run legacy:smoke:acceptance && npm run legacy:smoke:click && npm run legacy:smoke:runner && npm run legacy:smoke:session && npm run legacy:smoke:device-discovery && npm run legacy:smoke:evidence && npm run legacy:smoke:legacy-tools && npm run legacy:smoke:public-text && npm run legacy:smoke:public-payload && npm run legacy:smoke:validate && npm run legacy:smoke:visual && npm run legacy:smoke:workflow && npm run legacy:smoke:console-guards && npm run legacy:smoke:console && npm run legacy:check"
  },
  "dependencies": {
    "webdriverio": "^9.18.4"
  },
  "devDependencies": {
    "appium": "^3.5.2",
    "appium-xcuitest-driver": "^11.13.0"
  }
}
